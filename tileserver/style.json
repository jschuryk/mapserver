{
  "version": 8,
  "name": "ASM Basic",
  "sources": {
    "tiles": {
      "type": "vector",
      "url": "mbtiles://{tiles}"
    },
    "land": {
      "type": "geojson",
      "data": "http://localhost:3000/data/land.geojson"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#9ab4bc" }
    },
    {
      "id": "land-fill",
      "type": "fill",
      "source": "land",
      "paint": { "fill-color": "#b8b8b8", "fill-opacity": 1 }
    },
    {
      "id": "water-fill",
      "type": "fill",
      "source": "tiles",
      "source-layer": "water",
      "paint": { "fill-color": "#9ab4bc", "fill-opacity": 1 }
    },
    {
      "id": "waterway-line",
      "type": "line",
      "source": "tiles",
      "source-layer": "waterway",
      "minzoom": 8,
      "paint": {
        "line-color": "#7a9ea8",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 1, 10, 2]
      }
    },
    {
      "id": "road-primary-casing",
      "type": "line",
      "source": "tiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "primary"],
      "minzoom": 7,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#a8a8a8",
        "line-width": ["interpolate", ["linear"], ["zoom"], 7, 3.5, 10, 5]
      }
    },
    {
      "id": "road-trunk-casing",
      "type": "line",
      "source": "tiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "trunk"],
      "minzoom": 6,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#909090",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 4, 10, 6.5]
      }
    },
    {
      "id": "road-motorway-casing",
      "type": "line",
      "source": "tiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "motorway"],
      "minzoom": 5,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#787878",
        "line-width": ["interpolate", ["linear"], ["zoom"], 5, 4.5, 10, 8]
      }
    },
    {
      "id": "road-primary",
      "type": "line",
      "source": "tiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "primary"],
      "minzoom": 7,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#d0d0d0",
        "line-width": ["interpolate", ["linear"], ["zoom"], 7, 2, 10, 3.5]
      }
    },
    {
      "id": "road-trunk",
      "type": "line",
      "source": "tiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "trunk"],
      "minzoom": 6,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#c8c8c8",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 2.5, 10, 4.5]
      }
    },
    {
      "id": "road-motorway",
      "type": "line",
      "source": "tiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "motorway"],
      "minzoom": 5,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#b8b8b8",
        "line-width": ["interpolate", ["linear"], ["zoom"], 5, 3, 10, 6]
      }
    }
  ]
}
